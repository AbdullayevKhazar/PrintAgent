# Default: 9191
PRINT_AGENT_PORT=9191

# Default for browser fallback: 127.0.0.1
PRINT_AGENT_HOST=127.0.0.1

# Optional. If empty, Windows default printer is used.
# Use: npm run print-agent:list-printers
PRINT_AGENT_PRINTER_NAME=

# ESC/POS command strings are usually byte-oriented, so latin1 is the default.
# Change to utf8 only if your frontend intentionally sends UTF-8 text bytes.
PRINT_AGENT_RAW_ENCODING=latin1

# Keep below the frontend print timeout (3000ms). If printing takes longer,
# the agent returns HTTP 202 and continues the print job in the background.
PRINT_AGENT_RESPONSE_TIMEOUT_MS=2500

# PowerShell/Winspool job timeout.
PRINT_AGENT_PRINT_TIMEOUT_MS=20000

# Comma-separated browser origins that may call the local bridge directly.
# Keep this narrow; production PWA should use backend print queue instead.
PRINT_AGENT_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,https://testapp.nextcross.az,https://app.nextcross.az
PRINT_AGENT_AUTO_START=true

# Production print queue worker. If PRINT_API_BASE_URL or PRINT_BRANCH_ID is
# empty, the Electron worker stays disabled and only the local bridge runs.
PRINT_API_BASE_URL=
PRINT_BRANCH_ID=
PRINT_DEVICE_ID=
PRINT_QUEUE_ENABLED=true
PRINT_QUEUE_POLL_INTERVAL_MS=3000
PRINT_QUEUE_MAX_ATTEMPTS=3
PRINT_QUEUE_STALE_PRINTING_MS=120000
PRINT_QUEUE_REQUEST_TIMEOUT_MS=10000
